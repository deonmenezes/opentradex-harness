{
  "name": "opentradex",
  "version": "0.1.0",
  "description": "Lightweight AI trading harness for prediction markets, stocks, and crypto. Paper-first, easily switchable to live. Includes desktop app and web dashboard.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opentradex": "dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./risk": {
      "import": "./dist/risk.js",
      "types": "./dist/risk.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build && npm run build:dashboard",
    "build:dashboard": "cd packages/dashboard && npm install && npm run build",
    "build:desktop": "cd packages/desktop && npm install && npm run build",
    "build:desktop:win": "cd packages/desktop && npm run build:win",
    "build:desktop:mac": "cd packages/desktop && npm run build:mac",
    "dev": "tsc --watch",
    "dev:dashboard": "cd packages/dashboard && npm run dev",
    "start": "node dist/bin/cli.js",
    "gateway": "node dist/bin/cli.js run",
    "onboard": "node dist/bin/cli.js onboard",
    "ui": "npm run build:all && node packages/dashboard/dist/server.js",
    "desktop": "cd packages/desktop && npm run dev",
    "test": "node --test dist/**/*.test.js",
    "clean": "rm -rf dist packages/dashboard/dist packages/desktop/dist packages/desktop/release"
  },
  "keywords": [
    "trading",
    "prediction-markets",
    "kalshi",
    "polymarket",
    "alpaca",
    "stocks",
    "crypto",
    "ai-harness",
    "paper-trading",
    "trading-bot",
    "desktop-app",
    "electron"
  ],
  "author": "deonmenezes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deonmenezes/opentradex.git"
  },
  "bugs": {
    "url": "https://github.com/deonmenezes/opentradex/issues"
  },
  "homepage": "https://github.com/deonmenezes/opentradex#readme",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
