{
  "name": "@opentradex/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "OpenTradex Desktop App - Trading Command Cockpit",
  "author": "deonmenezes",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:store": "tsc && electron-builder --win appx --x64",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.opentradex.desktop",
    "productName": "OpenTradex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../dashboard/dist/client",
        "to": "dashboard"
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "appx",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "OpenTradex",
      "signingHashAlgorithms": ["sha256"],
      "signDlls": false,
      "rfc3161TimeStampServer": "http://timestamp.digicert.com"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "mas",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false
    },
    "linux": {
      "target": ["AppImage", "deb", "snap"],
      "icon": "assets/icon.png",
      "category": "Finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "appx": {
      "identityName": "OpenTradex.OpenTradex",
      "displayName": "OpenTradex",
      "publisher": "CN=OpenTradex",
      "publisherDisplayName": "OpenTradex",
      "applicationId": "OpenTradex",
      "backgroundColor": "#0a0f1e",
      "showNameOnTiles": true,
      "languages": ["en-US"]
    },
    "mas": {
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deonmenezes/opentradex.git",
    "directory": "packages/desktop"
  }
}
